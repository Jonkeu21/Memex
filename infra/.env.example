# Memex environment file — copy to infra/.env and fill in.
#
# `scripts/bootstrap.sh` writes this file for you. Hand-editing is fine but
# every key below must remain set: docker compose interpolation requires it.
#
# Env-var name conventions (binding, see CLAUDE.md):
#   MEMEX_CAPTURE_TOKEN_<LABEL>   capture API bearer tokens (one per submitter)
#   MEMEX_WORKER_*                worker tunables
#   MEMEX_TELEGRAM_*              bot tunables
#   MEMEX_DASHBOARD_*             dashboard tunables (Phase 6)
#   MEMEX_LOG_LEVEL               cross-cutting log level
#
# Comments after `#` are allowed; values must NOT be quoted.

# ─────────────────────────────────────────────────────────────────────────────
# Host paths (bind mounts)
# ─────────────────────────────────────────────────────────────────────────────

# Canonical vault root on the Pi. Bind-mounted into worker (rw),
# telegram_bot (ro), and dashboard (rw — triage actions move files).
MEMEX_VAULT_PATH=/srv/memex/vault

# SQLite + uploads. Hosts /srv/memex/data/memex.db and /srv/memex/data/uploads.
MEMEX_DATA_PATH=/srv/memex/data

# Syncthing config + state.
MEMEX_SYNCTHING_CONFIG=/srv/memex/syncthing

# Numeric uid/gid Syncthing should run as. Match the host user that owns
# MEMEX_VAULT_PATH so Obsidian on the Mac and Syncthing on the Pi don't fight.
MEMEX_UID=1000
MEMEX_GID=1000

# Container timezone — also drives JSON log timestamps if MEMEX_LOG_LEVEL=DEBUG
# adds wall-clock fields. Use an IANA zone name, e.g. "America/Los_Angeles".
TZ=UTC

# ─────────────────────────────────────────────────────────────────────────────
# Capture API
# ─────────────────────────────────────────────────────────────────────────────

# Bearer token for the Telegram bot. Must equal MEMEX_CAPTURE_API_TOKEN below
# (the bot is configured with this same value). The label suffix (`telegram`)
# is what the API records in queue.submitter as `api:telegram`.
MEMEX_CAPTURE_TOKEN_telegram=CHANGE_ME_64_HEX_CHARS

# Optional second token for ad-hoc curl-based captures from the Mac. Comment
# out if you don't use it.
# MEMEX_CAPTURE_TOKEN_devbox=CHANGE_ME_64_HEX_CHARS

# Maximum upload size (megabytes) accepted by /captures/file and /captures/voice.
MEMEX_CAPTURE_MAX_UPLOAD_MB=25

# ─────────────────────────────────────────────────────────────────────────────
# Worker
# ─────────────────────────────────────────────────────────────────────────────

# Polling cadence for the queue. CLAUDE.md fixes the default at 5 seconds.
MEMEX_WORKER_POLL_SECONDS=5

# Pause between non-empty ticks. The system's only Claude-Max-session throttle.
MEMEX_WORKER_BATCH_PAUSE_SECONDS=60

# Max items processed per tick.
MEMEX_WORKER_BATCH_MAX=10

# Max attempts before a row goes to status='failed'.
MEMEX_WORKER_MAX_ATTEMPTS=5

# Wall-clock cap on a single `claude -p` invocation.
MEMEX_WORKER_CLAUDE_TIMEOUT_SECONDS=180

# Whisper model file shipped in the worker image at /models/<filename>.
# Currently the only file the image ships is ggml-base.en.bin; switch the
# Dockerfile's WHISPER_MODEL_URL build arg if you need ggml-tiny.en.bin.
MEMEX_WHISPER_MODEL_FILE=ggml-base.en.bin

# ─────────────────────────────────────────────────────────────────────────────
# Telegram bot
# ─────────────────────────────────────────────────────────────────────────────

# BotFather token. Format: <numeric_id>:<35-char-secret>.
MEMEX_TELEGRAM_BOT_TOKEN=CHANGE_ME_FROM_BOTFATHER

# Comma-separated whitelist of Telegram chat IDs the bot will respond to.
# Leave empty during the very first bootstrap and add later via the
# `Adding a chat ID` runbook in docs/deployment.md — the bot will silently
# drop every message until at least one ID is listed.
MEMEX_TELEGRAM_ALLOWED_CHAT_IDS=

# Wall-clock cap on a single retrieval `claude -p` call from the bot.
MEMEX_TELEGRAM_CLAUDE_TIMEOUT_SECONDS=120

# Refuse to download Telegram payloads larger than this (megabytes).
MEMEX_TELEGRAM_MAX_DOWNLOAD_MB=25

# ─────────────────────────────────────────────────────────────────────────────
# Dashboard (Phase 6)
# ─────────────────────────────────────────────────────────────────────────────

# Single shared bearer token gating mutating dashboard endpoints (queue
# retry/cancel, inbox routing, taxonomy save, retrieval). The operator pastes
# this same value into the dashboard's Settings drawer on first use; it is
# stored in localStorage. The dashboard is single-user — there is no token
# label scheme, just one secret.
#
# Generate with: openssl rand -hex 32
MEMEX_DASHBOARD_BEARER_TOKEN=CHANGE_ME_64_HEX_CHARS

# Wall-clock cap on a single retrieval `claude -p` call from the dashboard.
MEMEX_DASHBOARD_CLAUDE_TIMEOUT_SECONDS=120

# ─────────────────────────────────────────────────────────────────────────────
# Cross-cutting
# ─────────────────────────────────────────────────────────────────────────────

# DEBUG | INFO | WARN | ERROR. Applied to every service.
MEMEX_LOG_LEVEL=INFO
